---
import FormRadio from './FormRadio.astro';
---

<section class="section">
  <h2>Section 5 – Allergen Management</h2>

  <FormRadio name="documentedAllergenControls" number={19} label="Do you have documented allergen controls?" />
  <FormRadio name="allergenProductsSegregated" number={20} label="Are allergen and non-allergen products segregated?" />
  <FormRadio name="allergenLabelsVerified" number={21} label="Are allergen labels verified before dispatch?" />
  <FormRadio name="allergenSpecificationsAvailable" number={22} label="Can you provide current allergen specifications?" />
</section>
