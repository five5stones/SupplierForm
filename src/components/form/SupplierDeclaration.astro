---

<section class="section">
  <h2>Supplier Declaration</h2>
  <p class="declaration-text">
    I confirm that the information provided is accurate and that Your Company will be notified of any
    significant changes affecting food safety, product quality, allergen management or legal compliance.
  </p>

  <label class="checkbox">
    <input type="checkbox" name="declarationAccepted" required />
    <span>I confirm the above declaration *</span>
  </label>

  <div class="grid">
    <label class="field">
      <span>Name *</span>
      <input type="text" name="declarationName" required />
    </label>
    <label class="field">
      <span>Position *</span>
      <input type="text" name="declarationPosition" required />
    </label>
    <label class="field">
      <span>Signature *</span>
      <input type="text" name="declarationSignature" required placeholder="Type full name as signature" />
    </label>
    <label class="field">
      <span>Date *</span>
      <input type="date" name="declarationDate" required />
    </label>
  </div>
</section>
