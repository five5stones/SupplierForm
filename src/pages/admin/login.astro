---
import '../../styles/admin.css';
import { loadAppConfig, getBrandName, getLogoUrl } from '../../lib/app-config';
import { hasUploadedLogo } from '../../lib/logo';

const appConfig = await loadAppConfig();
const brandName = getBrandName(appConfig);
const logoUrl = getLogoUrl(appConfig);
const logoUploaded = hasUploadedLogo(appConfig);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login — {brandName}</title>
  </head>
  <body class="admin-body">
    <div class="login-card">
      {logoUrl && (
        <img
          src={logoUrl}
          alt={brandName}
          class:list={['brand-logo', 'login-logo', { 'brand-logo-uploaded': logoUploaded }]}
        />
      )}
      <h1>Admin Login</h1>
      <p>{brandName} Supplier Form</p>
      <form id="login-form">
        <label class="admin-field">
          <span>Password</span>
          <input type="password" name="password" required autofocus />
        </label>
        <div id="login-error" class="admin-error" hidden></div>
        <button type="submit" class="admin-btn">Sign in</button>
      </form>
    </div>
  </body>
</html>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorEl = document.getElementById('login-error') as HTMLDivElement;

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    errorEl.hidden = true;

    const password = new FormData(form).get('password');
    const response = await fetch('/api/admin/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password }),
    });

    if (response.ok) {
      window.location.href = '/admin';
      return;
    }

    const result = await response.json();
    errorEl.textContent = result.error || 'Login failed';
    errorEl.hidden = false;
  });
</script>
